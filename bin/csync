#!/usr/bin/env bash
# csync — two-way sync of Claude Code session history with iCloud Drive.
# One command, no direction: merges both ways (newest file wins, nothing
# deleted) so every machine converges to the union of all sessions. Safe to
# run anytime; --update never clobbers a newer copy and no --delete means it
# never removes sessions. Run by hand, or automatically every 15 min via the
# precmd hook in .zshrc (which logs background runs to ~/Library/Logs/csync.log).
#
# Not run via launchd on purpose: iCloud Drive is TCC-protected and background
# agents are denied (granting /bin/bash Full Disk Access has no effect on recent
# macOS). The shell hook works because it runs in the Terminal's approved context.

set -euo pipefail

icloud="$HOME/Library/Mobile Documents/com~apple~CloudDocs/claude-sessions"
local_dir="$HOME/.claude/projects"

if [[ ! -d "$HOME/Library/Mobile Documents/com~apple~CloudDocs" ]]; then
  echo "iCloud Drive not found on this machine."
  exit 1
fi

mkdir -p "$icloud" "$local_dir"

# iCloud may keep file *contents* evicted (dataless placeholders) even though
# the names show up. rsync reads via mmap, which times out on those ("mmap:
# Operation timed out") instead of fetching them — and aborts. So force
# evicted files local first: ask the daemon to fetch (brctl), then a plain
# read() blocks until the bytes land.
echo "⟳ Materialising cloud-only files in iCloud…"
# Best-effort: brctl can exit non-zero (e.g. nothing to fetch) — never let that
# abort the sync under set -e, so swallow its status with `|| true`.
find "$icloud" -type f ! -name '.DS_Store' -exec brctl download {} + 2>/dev/null || true
while IFS= read -r -d '' f; do
  # Dataless placeholder: 0 blocks allocated but a non-zero logical size.
  if [[ "$(stat -f '%b' "$f" 2>/dev/null)" -eq 0 && "$(stat -f '%z' "$f" 2>/dev/null)" -gt 0 ]]; then
    cat "$f" >/dev/null 2>&1 || true
  fi
done < <(find "$icloud" -type f ! -name '.DS_Store' -print0 2>/dev/null)

# Merge both directions: iCloud → local, then local → iCloud. --update keeps
# the newer side on each file; no --delete, so sessions only ever accumulate.
echo "⟳ Syncing iCloud ↔ $local_dir"
rsync -a --update --exclude='.DS_Store' "$icloud/" "$local_dir/"
rsync -a --update --exclude='.DS_Store' "$local_dir/" "$icloud/"
echo "✓ csync complete"
