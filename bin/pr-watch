#!/usr/bin/env python3
# pr-watch — autonomously fix conflicting / CI-failing PRs in a fresh Claude session.
#
# Polls GitHub for open PRs on this repo and, when one has a MERGE CONFLICT or a
# FAILING CI check, spawns a detached tmux Claude session that resolves it and
# pushes — then notifies you (macOS notification + a PR comment) so you can attach
# and intervene. Built for `chrisobrien-ai/dotfiles`; scope is this one repo.
#
# WHY launchd is fine here (unlike csync): csync's launchd agent was abandoned
# because iCloud Drive is TCC-protected and background agents are denied on recent
# macOS. pr-watch touches NO TCC-protected dir — it only talks to `gh`, `git`, and
# `tmux` — so a LaunchAgent timer is the right tool. install.sh installs the agent
# but leaves it INERT: poll() is a no-op until you run `pr-watch enable`, so a
# fresh dotfiles clone on another machine never silently auto-pushes.
#
# Autonomy + guardrails (this thing edits code and pushes on its own):
#   • Opt-in     — does nothing unless ~/.config/pr-watch/enabled exists.
#   • Once/SHA   — acts at most once per (PR number, head commit); a new push makes
#                  it eligible again only when the head SHA changes.
#   • Attempt cap— at most MAX_ATTEMPTS distinct fixes per PR, then it gives up and
#                  flags the PR for manual attention (no infinite fix→fail→fix loop).
#   • Live guard — never spawns a second session for a PR already being fixed.
#   • Isolation  — each fix runs in its own git worktree at a DETACHED head, so it
#                  never disturbs the live symlinked tree (or a concurrent agent),
#                  and pushes via `git push origin HEAD:<branch>` (so the PR branch
#                  may be checked out elsewhere without a collision).
#   • Definitive — only acts on CONFLICTING or a concluded FAILURE; skips drafts,
#                  forks, and still-running CI.
#
# Verbs:  poll [--dry-run] · enable · disable · status · clean
# State:  ~/.cache/pr-watch/   Config flag: ~/.config/pr-watch/enabled
# Logs:   ~/Library/Logs/pr-watch.log   Kill switch: `pr-watch disable`

import argparse
import datetime
import json
import os
import shlex
import subprocess
import sys
import uuid

HOME = os.path.expanduser("~")
CONFIG_DIR = os.path.join(HOME, ".config", "pr-watch")
ENABLED_FLAG = os.path.join(CONFIG_DIR, "enabled")
# ~/.config/pr-watch/config — KEY=VALUE per line (sh-like, no quoting). Loaded
# BEFORE reading $PR_WATCH_REPO / $PR_WATCH_REPO_ROOT so launchd-driven polls
# pick up overrides (launchd hands the agent a minimal env; it does NOT source
# zsh, so an `export` in ~/.zshrc.local never reaches the every-5-min entry
# point). Process env still wins so an interactive `PR_WATCH_REPO=… pr-watch
# poll` ad-hoc override beats the file.
CONFIG_FILE = os.path.join(CONFIG_DIR, "config")


def _load_config_file():
    """Populate os.environ from CONFIG_FILE for any KEY not already set. Silent
    on missing file / malformed lines so a fresh machine just sees env defaults."""
    try:
        with open(CONFIG_FILE) as fh:
            for raw in fh:
                line = raw.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, _, value = line.partition("=")
                key = key.strip()
                if key and key not in os.environ:
                    os.environ[key] = value.strip()
    except OSError:
        pass


_load_config_file()

REPO = os.environ.get("PR_WATCH_REPO", "chrisobrien-ai/dotfiles")
SHORT = REPO.split("/")[-1]                 # "dotfiles" → session names pr-dotfiles-<N>

STATE_DIR = os.path.join(HOME, ".cache", "pr-watch")
STATE_FILE = os.path.join(STATE_DIR, "state.json")
WORKTREES = os.path.join(STATE_DIR, "worktrees")
TASKS_DIR = os.path.join(STATE_DIR, "tasks")
LOG = os.path.join(HOME, "Library", "Logs", "pr-watch.log")
TMUX_LOG_DIR = os.path.join(HOME, ".tmux-logs")

LABEL = "com.chrisobrien-ai.pr-watch"
PLIST = os.path.join(HOME, "Library", "LaunchAgents", LABEL + ".plist")
MAX_ATTEMPTS = 2

# Repo root = the dir holding this script's bin/. realpath resolves the ~/bin
# symlink back into the checkout, so worktrees are created from the real repo.
# Override with $PR_WATCH_REPO_ROOT when watching a foreign $PR_WATCH_REPO so
# `git fetch`/`git worktree add` target the matching local checkout (otherwise
# the polled repo and the worktree-source repo would silently diverge).
REPO_ROOT = os.environ.get("PR_WATCH_REPO_ROOT") or os.path.dirname(
    os.path.dirname(os.path.realpath(__file__)))


# ─── small helpers ─────────────────────────────────────────────────────────────

def log(msg):
    """Append a timestamped line to the log and echo it (launchd captures stdout)."""
    line = "%s  %s" % (datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S"), msg)
    print(line, flush=True)
    try:
        os.makedirs(os.path.dirname(LOG), exist_ok=True)
        with open(LOG, "a") as fh:
            fh.write(line + "\n")
    except OSError:
        pass


def run(cmd, cwd=None, check=False, capture=True):
    """Thin subprocess wrapper. Returns CompletedProcess; never raises unless check."""
    return subprocess.run(cmd, cwd=cwd, check=check, text=True,
                          stdout=subprocess.PIPE if capture else None,
                          stderr=subprocess.PIPE if capture else None)


def gh_json(args):
    """Run `gh … --json …` and parse stdout. Returns None on any failure."""
    r = run(["gh"] + args)
    if r.returncode != 0:
        log("gh failed: %s :: %s" % (" ".join(args), (r.stderr or "").strip()))
        return None
    try:
        return json.loads(r.stdout or "null")
    except json.JSONDecodeError:
        log("gh returned unparseable JSON for: %s" % " ".join(args))
        return None


def load_state():
    try:
        with open(STATE_FILE) as fh:
            return json.load(fh)
    except (OSError, json.JSONDecodeError):
        return {"acted": {}, "attempts": {}, "gaveup": {}}


def save_state(state):
    os.makedirs(STATE_DIR, exist_ok=True)
    tmp = STATE_FILE + ".tmp"
    with open(tmp, "w") as fh:
        json.dump(state, fh, indent=2)
    os.replace(tmp, STATE_FILE)


def tmux_alive(session):
    return run(["tmux", "has-session", "-t", session]).returncode == 0


def notify(title, message):
    """Best-effort macOS notification; silently no-ops if osascript is unavailable."""
    body = 'display notification %s with title %s' % (
        json.dumps(message), json.dumps(title))
    try:
        run(["osascript", "-e", body])
    except FileNotFoundError:
        pass


# ─── CI / conflict detection ────────────────────────────────────────────────────

def failing_checks(rollup):
    """Names of concluded-FAILURE checks in a statusCheckRollup (mixed CheckRun /
    StatusContext shapes). Still-running checks are NOT failures."""
    bad = []
    for c in rollup or []:
        # CheckRun: conclusion in {SUCCESS, FAILURE, …}; StatusContext: state.
        concl = (c.get("conclusion") or "").upper()
        state = (c.get("state") or "").upper()
        if concl in ("FAILURE", "TIMED_OUT", "CANCELLED", "ACTION_REQUIRED") \
           or state in ("FAILURE", "ERROR"):
            bad.append(c.get("name") or c.get("context") or "check")
    return bad


def pending_checks(rollup):
    """Names of checks still in-flight on this commit (not yet COMPLETED). After a
    new push, GitHub often keeps OLDER failed runs in the rollup alongside fresh
    in-progress ones — acting on the stale failure before the new CI finishes
    causes premature autonomous sessions, so the CI branch in `classify` waits."""
    pend = []
    for c in rollup or []:
        # CheckRun: status in {QUEUED, IN_PROGRESS, COMPLETED}; StatusContext:
        # state in {PENDING, EXPECTED, SUCCESS, FAILURE, ERROR}.
        status = (c.get("status") or "").upper()
        state = (c.get("state") or "").upper()
        if status and status != "COMPLETED":
            pend.append(c.get("name") or c.get("context") or "check")
        elif not status and state in ("PENDING", "EXPECTED"):
            pend.append(c.get("name") or c.get("context") or "check")
    return pend


def classify(pr):
    """Return (reason_str, detail) if the PR needs a fix, else (None, None)."""
    if pr.get("isDraft") or pr.get("isCrossRepository"):
        return None, None
    base = pr.get("baseRefName") or "main"
    # mergeable can be UNKNOWN while GitHub is still computing it; mergeStateStatus
    # DIRTY is the authoritative "conflicts with base" signal in that window.
    if (pr.get("mergeable") or "").upper() == "CONFLICTING" \
       or (pr.get("mergeStateStatus") or "").upper() == "DIRTY":
        return "merge conflict with %s" % base, "conflict"
    rollup = pr.get("statusCheckRollup")
    bad = failing_checks(rollup)
    if bad:
        # Don't act on a failure while other checks are still in flight for this
        # commit — the in-progress run may be the one that supersedes it.
        if pending_checks(rollup):
            return None, None
        return "failing CI: " + ", ".join(bad), "ci:" + ",".join(bad)
    return None, None


# ─── the fix session ─────────────────────────────────────────────────────────────

def write_brief(pr, reason, detail):
    """Write the autonomous fixer's task brief OUTSIDE the worktree (so the session
    can't accidentally commit it). Returns the absolute path."""
    os.makedirs(TASKS_DIR, exist_ok=True)
    num, branch, sha = pr["number"], pr["headRefName"], pr["headRefOid"]
    base = pr.get("baseRefName") or "main"
    is_conflict = detail == "conflict"
    checks_hint = ""
    if not is_conflict:
        r = run(["gh", "pr", "checks", str(num), "--repo", REPO])
        checks_hint = "\n\nFailing checks (from `gh pr checks %d`):\n```\n%s\n```" % (
            num, (r.stdout or "").strip()[:2000])
    fix_step = (
        "1. `git fetch origin`\n"
        "2. `git merge origin/{base}` — resolve every conflict by UNION, preserving "
        "the intent of BOTH sides (do not drop either feature). Then `git add -A` "
        "and `git commit --no-edit`.".format(base=base)
        if is_conflict else
        "1. `git fetch origin`\n"
        "2. Investigate the failing check(s) above (`gh run view <run-id> --log-failed` "
        "or read the offending file), fix the ROOT CAUSE, then commit the fix.")
    brief = """# pr-watch task — PR #{num}

You are an autonomous fix agent. You are in a **detached** git worktree of `{repo}`
at `{wt}` (HEAD = the PR's head commit `{sha:.12}`). The PR's branch is `{branch}`.

**Problem:** {reason}.

Fix it, then push to the PR branch. Steps:

{fix_step}
3. Validate before pushing:
   - `zsh -n .zshrc`
   - `python3 -c "import py_compile; py_compile.compile('bin/t', cfile='/tmp/t.pyc', doraise=True)"`
   - py_compile any other changed Python; `shellcheck` any changed bash if available.
4. Push to the PR branch (HEAD is detached, so push the ref explicitly):
   `git push origin HEAD:{branch}`
5. Confirm: `gh pr view {num} --repo {repo} --json mergeable,statusCheckRollup`.
6. **Stop.** Do NOT open new PRs, switch branches, force-push, or touch anything
   outside this worktree.

If you cannot resolve it safely, STOP and run:
`gh pr comment {num} --repo {repo} --body "pr-watch: could not auto-fix — needs manual attention. <one-line reason>"`
{checks_hint}
""".format(num=num, repo=REPO, wt="{wt}", sha=sha, branch=branch,
           reason=reason, fix_step=fix_step, checks_hint=checks_hint)
    path = os.path.join(TASKS_DIR, "pr%d.md" % num)
    # wt is filled in by the caller once the worktree path is known
    with open(path, "w") as fh:
        fh.write(brief)
    return path


def spawn_fix(pr, reason, detail):
    """Create an isolated worktree + a detached-HEAD tmux Claude session that fixes
    the PR autonomously. Returns the session name, or None on failure."""
    num, branch, sha = pr["number"], pr["headRefName"], pr["headRefOid"]
    session = "pr-%s-%d" % (SHORT, num)
    wt = os.path.join(WORKTREES, "%s-pr%d" % (SHORT, num))

    run(["git", "fetch", "origin", "--quiet"], cwd=REPO_ROOT)

    # Reset a stale worktree (no live session owns it — checked by the caller).
    if os.path.exists(wt):
        run(["git", "worktree", "remove", "--force", wt], cwd=REPO_ROOT)
    run(["git", "worktree", "prune"], cwd=REPO_ROOT)
    add = run(["git", "worktree", "add", "--detach", wt, sha], cwd=REPO_ROOT)
    if add.returncode != 0:
        log("worktree add failed for PR #%d: %s" % (num, (add.stderr or "").strip()))
        return None

    brief_path = write_brief(pr, reason, detail)
    # Fill the worktree path into the brief now that it exists.
    with open(brief_path) as fh:
        body = fh.read().replace("{wt}", wt)
    with open(brief_path, "w") as fh:
        fh.write(body)

    os.makedirs(TMUX_LOG_DIR, exist_ok=True)
    sid = str(uuid.uuid4()).lower()
    tmux_log = os.path.join(TMUX_LOG_DIR, session + ".log")
    if run(["tmux", "new-session", "-d", "-s", session, "-c", wt]).returncode != 0:
        log("tmux new-session failed for %s" % session)
        return None
    run(["tmux", "set-option", "-t", session, "window-size", "latest"])
    run(["tmux", "pipe-pane", "-t", session, "-o", "cat >> %s" % shlex.quote(tmux_log)])
    run(["tmux", "set-environment", "-t", session, "CLAUDE_RESUME_ID", sid])

    prompt = "Read %s and complete the task it describes, then stop." % brief_path
    keys = "claude --dangerously-skip-permissions --session-id %s %s; exit" % (
        sid, shlex.quote(prompt))
    run(["tmux", "send-keys", "-t", session, keys, "Enter"])
    return session


# ─── verbs ───────────────────────────────────────────────────────────────────────

def cmd_poll(args):
    if not args.dry_run and not os.path.exists(ENABLED_FLAG):
        log("disabled (no %s) — nothing to do. Run `pr-watch enable` to arm." % ENABLED_FLAG)
        return 0

    prs = gh_json(["pr", "list", "--repo", REPO, "--state", "open", "--json",
                   "number,headRefName,headRefOid,baseRefName,isDraft,isCrossRepository,"
                   "mergeable,mergeStateStatus,statusCheckRollup,author"])
    if prs is None:
        return 1
    log("polled %s — %d open PR(s)%s" % (REPO, len(prs), " [dry-run]" if args.dry_run else ""))

    state = load_state()
    acted = state.setdefault("acted", {})
    attempts = state.setdefault("attempts", {})
    gaveup = state.setdefault("gaveup", {})
    changed = False

    for pr in prs:
        num = pr["number"]
        reason, detail = classify(pr)
        if not reason:
            continue
        key = "%d:%s" % (num, pr["headRefOid"])
        session = "pr-%s-%d" % (SHORT, num)

        if key in acted:
            continue                                   # already handled this exact commit
        if tmux_alive(session):
            log("PR #%d already has a live fix session (%s) — skipping" % (num, session))
            continue
        if attempts.get(str(num), 0) >= MAX_ATTEMPTS:
            if not gaveup.get(str(num)):
                log("PR #%d hit the attempt cap (%d) — flagging for manual attention"
                    % (num, MAX_ATTEMPTS))
                notify("pr-watch", "PR #%d needs manual attention (auto-fix gave up)" % num)
                gaveup[str(num)] = True
                changed = True
            continue

        if args.dry_run:
            log("WOULD fix PR #%d — %s" % (num, reason))
            continue

        log("fixing PR #%d — %s" % (num, reason))
        spawned = spawn_fix(pr, reason, detail)
        if not spawned:
            log("spawn failed for PR #%d" % num)
            continue
        acted[key] = {"ts": datetime.datetime.now().isoformat(timespec="seconds"),
                      "reason": reason, "session": spawned}
        attempts[str(num)] = attempts.get(str(num), 0) + 1
        changed = True
        notify("pr-watch", "PR #%d: %s — fixing in %s" % (num, reason, spawned))
        run(["gh", "pr", "comment", str(num), "--repo", REPO, "--body",
             "🤖 **pr-watch** started an autonomous fix session for this PR "
             "(%s).\n\nAttach to watch or intervene:\n```\ntmux attach -t %s\n```\n"
             "It validates, commits, and pushes on its own. Abort anytime with "
             "`tmux kill-session -t %s`." % (reason, spawned, spawned)])

    if changed:
        save_state(state)
    return 0


def _launchctl(action):
    uid = os.getuid()
    if action == "bootstrap" and os.path.exists(PLIST):
        run(["launchctl", "bootstrap", "gui/%d" % uid, PLIST])
    elif action == "bootout":
        run(["launchctl", "bootout", "gui/%d/%s" % (uid, LABEL)])


def cmd_enable(args):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    open(ENABLED_FLAG, "a").close()
    if not os.path.exists(PLIST):
        log("enabled — no plist installed yet; run install.sh to schedule polling")
        return 0
    _launchctl("bootstrap")
    # `launchctl list <label>` exits 0 only when the job is actually loaded —
    # the source of truth used by `cmd_status`. `bootstrap` itself returns
    # quietly when the agent is already loaded (or fails silently if the plist
    # is malformed), so don't conflate "plist on disk" with "agent scheduled".
    loaded = run(["launchctl", "list", LABEL]).returncode == 0
    log("enabled — %s" % ("LaunchAgent bootstrapped (polls every 5 min)" if loaded
                          else "plist on disk but launchd did not load it; "
                               "try `launchctl bootout gui/$(id -u)/%s` and re-run" % LABEL))
    return 0


def cmd_disable(args):
    try:
        os.remove(ENABLED_FLAG)
    except OSError:
        pass
    _launchctl("bootout")
    log("disabled — flag removed and LaunchAgent booted out")
    return 0


def cmd_status(args):
    print("repo:     %s" % REPO)
    print("enabled:  %s" % ("yes" if os.path.exists(ENABLED_FLAG) else "no (pr-watch enable)"))
    print("plist:    %s" % ("installed" if os.path.exists(PLIST) else "not installed (install.sh)"))
    loaded = run(["launchctl", "list", LABEL]).returncode == 0
    print("launchd:  %s" % ("loaded" if loaded else "not loaded"))
    state = load_state()
    live = []
    if os.path.isdir(WORKTREES):
        for d in sorted(os.listdir(WORKTREES)):
            s = "pr-%s-%s" % (SHORT, d.rsplit("pr", 1)[-1])
            live.append("  %s  worktree=%s  session=%s" % (
                d, "yes", "live" if tmux_alive(s) else "dead"))
    print("worktrees:" + ("\n" + "\n".join(live) if live else " none"))
    print("attempts: %s" % (json.dumps(state.get("attempts", {})) or "{}"))
    gave = [k for k in state.get("gaveup", {})]
    if gave:
        print("gave up:  PR " + ", ".join(gave) + " (manual attention)")
    print("log:      %s" % LOG)
    return 0


def cmd_clean(args):
    """Remove worktrees whose fix session is no longer live, and prune state for
    PRs that are no longer open."""
    removed = 0
    if os.path.isdir(WORKTREES):
        for d in list(os.listdir(WORKTREES)):
            num = d.rsplit("pr", 1)[-1]
            session = "pr-%s-%s" % (SHORT, num)
            if not tmux_alive(session):
                run(["git", "worktree", "remove", "--force",
                     os.path.join(WORKTREES, d)], cwd=REPO_ROOT)
                removed += 1
    run(["git", "worktree", "prune"], cwd=REPO_ROOT)
    # Drop acted/attempts/gaveup for PRs that are no longer open.
    prs = gh_json(["pr", "list", "--repo", REPO, "--state", "open", "--json", "number"])
    if prs is not None:
        openset = {str(p["number"]) for p in prs}
        state = load_state()
        for bucket in ("attempts", "gaveup"):
            for k in list(state.get(bucket, {})):
                if k not in openset:
                    del state[bucket][k]
        for k in list(state.get("acted", {})):
            if k.split(":")[0] not in openset:
                del state["acted"][k]
        save_state(state)
    log("clean — removed %d stale worktree(s), pruned closed-PR state" % removed)
    return 0


def build_parser():
    p = argparse.ArgumentParser(
        prog="pr-watch",
        description="Autonomously fix conflicting / CI-failing PRs in a fresh Claude session.")
    sub = p.add_subparsers(dest="verb", metavar="<verb>")
    sp = sub.add_parser("poll", help="detect PRs needing a fix and act (LaunchAgent entrypoint)")
    sp.add_argument("--dry-run", action="store_true", help="detect + log only; spawn nothing")
    sub.add_parser("enable", help="arm the watcher on this machine + load the LaunchAgent")
    sub.add_parser("disable", help="disarm + boot out the LaunchAgent (kill switch)")
    sub.add_parser("status", help="show enabled state, tracked PRs, live fix sessions")
    sub.add_parser("clean", help="prune stale worktrees + closed-PR state")
    return p


VERBS = {"poll": cmd_poll, "enable": cmd_enable, "disable": cmd_disable,
         "status": cmd_status, "clean": cmd_clean}


def main(argv):
    args = build_parser().parse_args(argv)
    if not args.verb:
        build_parser().print_help()
        return 0
    return VERBS[args.verb](args)


if __name__ == "__main__":
    try:
        sys.exit(main(sys.argv[1:]))
    except KeyboardInterrupt:
        sys.exit(130)
    except BrokenPipeError:
        sys.exit(0)
