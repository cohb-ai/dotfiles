#!/usr/bin/env bash
# claude-stamp-tmux — SessionStart hook. Two jobs:
#   1. (in tmux) stamp this Claude session's id onto its tmux session as
#      CLAUDE_RESUME_ID, so tplan/tpop/dev can target the *exact* session even when
#      several slots share one project dir.
#   2. (always) record this session in a foreground registry — one file per live
#      claude pid, `<session_id>\t<cwd>` — so `dev ls` can map a FOREGROUND (non-tmux)
#      claude back to its session id, and thus its real transcript title. macOS won't
#      let `dev ls` read another process's env, and csync scrambles transcript
#      birthtimes, so the only reliable pid→session_id link is recorded here at start.
#
# The tmux stamp fixes: tplan/tpop resolve a slot's session id from CLAUDE_RESUME_ID,
# and when it's unset they fall back to "newest .jsonl by mtime in the project dir" —
# wrong when e.g. dev-ff-1..5 share one ~/.claude/projects/<enc>/ folder (it returns
# whichever *sibling* slot wrote last). _dev_new_session/_dev_resume_session already
# stamp the id, but a session started any other way (bare `claude`) never got stamped.
#
# Running as a SessionStart hook closes the gap for *every* launch path: it fires
# inside the running session (so it knows its own id) and in the tmux pane's context
# (so `tmux set-environment` lands on the right session via the inherited $TMUX_PANE).
# Always exits 0 so it can never block a session from starting.
#
# Wired via claude/settings.json -> hooks.SessionStart. session_id + cwd arrive in the
# hook's JSON payload on stdin; we fall back to $CLAUDE_CODE_SESSION_ID / $PWD.
set -uo pipefail

IFS=$'\t' read -r sid cwd < <(python3 -c 'import sys, json
try:
    d = json.load(sys.stdin)
    print("\t".join([d.get("session_id","") or "", d.get("cwd","") or ""]))
except Exception:
    print("\t")' 2>/dev/null) || { sid=""; cwd=""; }
[[ -n $sid ]] || sid=${CLAUDE_CODE_SESSION_ID:-}
[[ -n $sid ]] || exit 0
[[ -n $cwd ]] || cwd=$PWD

# Registry: key by the LIVE claude pid (an ancestor of this hook), so `dev ls` can
# look it up for a running foreground claude. Walk up from $PPID to the nearest
# process named `claude`; record under it. (`dev ls` prunes dead-pid entries.)
pid=$PPID comm="" n=0
while [[ -n $pid && $pid != 1 && $n -lt 10 ]]; do
  comm=$(ps -o comm= -p "$pid" 2>/dev/null); comm=${comm##*/}
  [[ $comm == claude ]] && break
  pid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' '); n=$((n+1))
done
if [[ $comm == claude && -n $pid ]]; then
  reg="${XDG_CACHE_HOME:-$HOME/.cache}/claude-sessions"
  # shellcheck disable=SC2015  # best-effort write; the `|| true` is the intended catch-all
  mkdir -p "$reg" 2>/dev/null && printf '%s\t%s\n' "$sid" "$cwd" > "$reg/$pid" 2>/dev/null || true
fi

# shellcheck disable=SC2015  # best-effort stamp; never fail the hook
[[ -n ${TMUX:-} ]] && tmux set-environment CLAUDE_RESUME_ID "$sid" 2>/dev/null || true
exit 0
