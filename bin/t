#!/usr/bin/env python3
# t — Claude session manager: open/list/move tmux'd Claude sessions (gh-style).
#
# Single front door for the Claude-session workflow (was the dev/tpush/tpop/tbeam/
# tread/tplan/tpaste/tfind/on family). gh-style: `t <verb> [args] [--flags]`, -h
# everywhere. This BIN owns argument parsing, help, config, the cross-host fan-out,
# rendering, and the Python-shaped verbs. Verbs that must manipulate the CALLING
# shell (cd + `claude -r` in the current terminal, the tpush sentinel handoff) are
# driven by the thin `t()` zsh shim via `t __resolve …` — a bin subprocess cannot
# cd the parent shell or exec into its TTY.
#
# Config: ~/.config/t/config.sh, derived from the live zsh arrays by _t_sync_config
# in .zshrc (DEV_REPOS / DEV_BRANCHES / REMOTE_HOSTS / DEV_BRANCH). Parsed here with
# a strict line regex — never sourced (it is shell, but ~/.zshrc.local is not, and
# we never execute either).
#
# Hybrid: the intricate, battle-tested tmux/ps introspection + transcript resolution
# (the _dev_* helpers) stay as zsh functions; this bin invokes them via `zsh -lic`
# for the data and renders in Python. Reimplementing ps-tree walking buys nothing.

import argparse
import glob
import os
import re
import shlex
import shutil
import subprocess
import sys

HOME = os.path.expanduser("~")
CONFIG = os.path.join(os.environ.get("XDG_CONFIG_HOME", os.path.join(HOME, ".config")), "t", "config.sh")

# Every zsh helper we spawn is `zsh -lic` (login+interactive — required so .zshrc is
# sourced and the _dev_* functions exist). An interactive login shell exiting under
# macOS Terminal.app triggers its shell-session-save, which prints "Saving session…"
# noise to stderr on every `t ls`/`t read`/etc. Disable it for our children (inherited
# by subprocess + execvp); does not affect the user's own shell.
os.environ["SHELL_SESSIONS_DISABLE"] = "1"

# Job-control noise prelude, prepended to every zsh snippet we spawn. The fan-out
# helpers run `&` + `wait` (e.g. _dev_rows_all behind `t ls -r`). When the spawned
# `zsh -lic` inherits a controlling tty (it does from a real terminal), -i turns on
# MONITOR (job control), so it prints job notices during the run and, crucially,
# "warning: N jobs SIGHUPed" at *exit*. _dev_rows_all's own `setopt local_options
# no_monitor` cannot fix the exit warning: local_options restores MONITOR=on when the
# function returns, before the shell exits. Setting it here keeps MONITOR off for the
# whole spawned-shell lifetime — quiet during the run AND at exit — and only touches
# our throwaway capture shells, never the user's interactive shell (or the `$(…)`
# subshell callers of _dev_rows_all, which already run with job control off).
ZSH_PRELUDE = "setopt no_monitor no_notify 2>/dev/null; "

# ─── config ──────────────────────────────────────────────────────────────────

_CFG_LINE = re.compile(
    r"^(DEV_REPOS|DEV_BRANCHES|REMOTE_HOSTS|DEV_WORKTREE)\[([^\]]+)\]=(.*)$"
    r"|^(DEV_BRANCH|DEV_WORKTREE_ROOT|DEV_WORKTREE_DEFAULT)=(.*)$")


def _unquote(v):
    """Strip one layer of zsh ${(q)} quoting (backslash escapes / quotes)."""
    v = v.strip()
    if not v:
        return ""
    try:
        parts = shlex.split(v)
        return parts[0] if parts else ""
    except ValueError:
        return v


class Config:
    def __init__(self):
        self.repos = {}      # alias -> path
        self.branches = {}   # alias -> branch
        self.hosts = {}      # alias -> ssh target
        self.branch = "dev/claude-1"
        self.worktree = {}   # alias -> opt-out flag (0/no/off → shared-tree)
        self.worktree_root = os.path.join(HOME, "code", ".worktrees")
        self.worktree_default = "1"
        self._load()

    def _load(self):
        try:
            with open(CONFIG, errors="ignore") as fh:
                lines = fh.readlines()
        except OSError:
            return  # graceful: no repos configured (mirrors zsh's degradation)
        for line in lines:
            m = _CFG_LINE.match(line.rstrip("\n"))
            if not m:
                continue
            if m.group(1):
                arr, key, val = m.group(1), m.group(2), _unquote(m.group(3))
                {"DEV_REPOS": self.repos, "DEV_BRANCHES": self.branches,
                 "REMOTE_HOSTS": self.hosts, "DEV_WORKTREE": self.worktree}[arr][key] = val
            elif m.group(4) == "DEV_BRANCH":
                self.branch = _unquote(m.group(5))
            elif m.group(4) == "DEV_WORKTREE_ROOT":
                self.worktree_root = _unquote(m.group(5))
            elif m.group(4) == "DEV_WORKTREE_DEFAULT":
                self.worktree_default = _unquote(m.group(5))

    def repo_of_dir(self, cwd):
        """(alias, slot) for a path — the Python twin of zsh _dev_repo_of_dir. slot is
        the worktree's own slot ($DEV_WORKTREE_ROOT/<basename>/<slot>), else "". Alias
        choice mirrors zsh: the key equal to the basename wins, else the shortest key.
        (None, None) when no repo matches."""
        base, slot = None, ""
        root = self.worktree_root
        if root and cwd.startswith(root + "/"):
            parts = cwd[len(root) + 1:].split("/")
            if len(parts) >= 2:
                base, slot = parts[0], parts[1]
        if base is None:
            best = ""
            for path in self.repos.values():
                if cwd == path or cwd.startswith(path + "/"):
                    if len(path) > len(best):
                        best = path
            if not best:
                return (None, None)
            base = os.path.basename(best)
        matches = [k for k, v in self.repos.items() if os.path.basename(v) == base]
        if not matches:
            return (None, None)
        if base in matches:
            return (base, slot)
        return (min(matches, key=len), slot)

    def repo_dir_for_cwd(self, cwd):
        """Canonical DEV_REPOS dir for cwd (or for the worktree containing it), else ''.
        Worktree-aware via repo_of_dir."""
        alias, _ = self.repo_of_dir(cwd)
        return self.repos.get(alias, "") if alias else ""


# ─── shell-out helpers ─────────────────────────────────────────────────────────

def zsh_capture(snippet):
    """Run a zsh login+interactive snippet, return stdout (stderr passes through).

    `-lic` is the same context the remote fan-out uses: ~/bin and Homebrew tmux/fzf
    are only on the login/interactive PATH, and the _dev_* helpers are defined there.
    """
    try:
        r = subprocess.run(["zsh", "-lic", ZSH_PRELUDE + snippet], stdout=subprocess.PIPE, text=True)
        return r.stdout
    except FileNotFoundError:
        return ""


# ─── rendering ───────────────────────────────────────────────────────────────

class Style:
    def __init__(self):
        tty = sys.stdout.isatty()
        self.g = "\033[32m" if tty else ""
        self.c = "\033[36m" if tty else ""
        self.y = "\033[2m" if tty else ""
        self.b = "\033[1m" if tty else ""
        self.r = "\033[0m" if tty else ""


def _columns():
    return shutil.get_terminal_size((80, 24)).columns


def _truncate(s, avail):
    if len(s) > avail:
        return s[:avail - 1] + "…"
    return s


def _parse_rows(text, host_prefixed=False):
    """Parse _dev_session_rows / _dev_rows_all output into dicts."""
    rows = []
    for line in text.splitlines():
        if not line:
            continue
        f = line.split("\t")
        if host_prefixed:
            if len(f) < 7:
                continue
            host, sid, cwd, slot, state, context, summary = f[:7]
        else:
            if len(f) < 6:
                continue
            host = "local"
            sid, cwd, slot, state, context, summary = f[:6]
        rows.append(dict(host=host, sid=sid, cwd=cwd, slot=slot,
                         state=state, context=context, summary=summary))
    return rows


def _scope_filter(rows, scope, wt_scope=""):
    """Keep rows whose cwd is under <scope> OR under <wt_scope> (the repo's worktree
    root $DEV_WORKTREE_ROOT/<basename>, where per-session worktrees live)."""
    if not scope:
        return rows
    def ok(c):
        if c == scope or c.startswith(scope + "/"):
            return True
        return bool(wt_scope) and c.startswith(wt_scope + "/")
    return [r for r in rows if ok(r["cwd"])]


def _header(st, scope):
    note = ""
    if scope:
        # Make the scoped repo prominent (bold cyan) — the rest of the note stays dim.
        repo = os.path.basename(scope)
        note = f"   {st.y}(repo: {st.r}{st.b}{st.c}{repo}{st.r}{st.y} — --all for all){st.r}"
    return f"dev sessions   {st.g}●{st.r} attached · {st.c}✓{st.r} active context{note}"


def cmd_ls(cfg, args):
    scope = "" if args.all else cfg.repo_dir_for_cwd(os.getcwd())
    wt_scope = os.path.join(cfg.worktree_root, os.path.basename(scope)) if scope else ""
    st = Style()
    if args.remote:
        rows = _scope_filter(_parse_rows(zsh_capture("_dev_rows_all"), host_prefixed=True), scope, wt_scope)
        if not rows:
            where = f" in {os.path.basename(scope)} (t ls -r --all for every repo)," if scope else ""
            print(f"No dev sessions running{where} on this machine or any reachable host.")
            return 0
        _render_remote(rows, scope, st)
    else:
        rows = _scope_filter(_parse_rows(zsh_capture("_dev_session_rows")), scope, wt_scope)
        if not rows:
            where = f" in {os.path.basename(scope)}" if scope else ""
            hints = ([f"t ls --all for every repo"] if scope else []) + \
                    (["t ls -r for other machines"] if cfg.hosts else [])
            tail = f"  ({' · '.join(hints)})" if hints else ""
            print(f"No dev sessions running{where}.{tail}")
            return 0
        _render_local(rows, scope, st, bool(cfg.hosts))
    return 0


def _render_local(rows, scope, st, has_remote=False):
    name_w = max([7] + [len(r["slot"]) for r in rows])
    avail = _columns() - 11 - name_w
    if avail < 12:
        avail = 80 - 11 - name_w
    print(_header(st, scope))
    print()
    print(f"  {st.y}{'STATUS':<8}{'SESSION':<{name_w}} WORKING ON{st.r}")
    has_fg = False
    for r in rows:
        amark = f"{st.g}●{st.r}" if r["state"] == "attached" else "○"
        cmark = f"{st.c}✓{st.r}" if r["context"] == "active" else " "
        summary = _truncate(r["summary"], avail)
        print(f"  {amark} {cmark}     {r['slot']:<{name_w}} {st.y}{summary}{st.r}")
        if ":" in r["slot"]:                       # colon marks a foreground row
            has_fg = True
    foot = "reattach: t open <repo> <slot>"
    if has_fg:
        foot += " · foreground: t open <id>"
    if has_remote:
        foot += " · other machines: t ls -r"
    print()
    print(f"  {st.y}{foot}{st.r}")


def _render_remote(rows, scope, st):
    host_w = max([4] + [len(r["host"]) for r in rows if r["host"] != "local"])
    name_w = max([7] + [len(r["slot"]) for r in rows])
    avail = _columns() - 12 - host_w - name_w
    if avail < 12:
        avail = 80 - 12 - host_w - name_w
    print(_header(st, scope))
    print()
    print(f"  {st.y}{'STATUS':<8}{'HOST':<{host_w}} {'SESSION':<{name_w}} WORKING ON{st.r}")
    has_fg = False
    for r in rows:
        amark = f"{st.g}●{st.r}" if r["state"] == "attached" else "○"
        cmark = f"{st.c}✓{st.r}" if r["context"] == "active" else " "
        summary = _truncate(r["summary"], avail)
        hostcell = "" if r["host"] == "local" else r["host"]
        print(f"  {amark} {cmark}     {hostcell:<{host_w}} {r['slot']:<{name_w}} {st.y}{summary}{st.r}")
        if ":" in r["slot"]:                       # colon marks a foreground row
            has_fg = True
    foot = ("attach (auto-finds its host): t open <repo> <slot> · "
            "pull here: t beam <repo> <slot> --from <host>")
    if has_fg:
        foot += " · foreground: t on <host> t open <id>"
    print()
    print(f"  {st.y}{foot}{st.r}")


# ─── machine-readable (remote contract) ────────────────────────────────────────

def cmd_session_rows(cfg, args):
    """The per-host scan behind `t ls -r`. Delegates to the proven zsh helper."""
    sys.stdout.write(zsh_capture("_dev_session_rows"))
    return 0


def cmd_land(cfg, args):
    """Resume a beamed session on this host. Reads TB_CWD/TB_SID/TB_MODE/TB_ATTACH
    from the env (set by the beam orchestrator over ssh, dodging nested-quote hell)
    and delegates to the proven zsh _tbeam_land."""
    os.execvp("zsh", ["zsh", "-lic", "_tbeam_land"])


def cmd_kill_owner(cfg, args):
    """Stop the local dev slot that owns TB_SID (the MOVE / one-live-owner step).
    Delegates to the proven zsh _tbeam_kill_owner."""
    os.execvp("zsh", ["zsh", "-lic", "_tbeam_kill_owner"])


# ─── subprocess-safe verbs ─────────────────────────────────────────────────────

def _set_term_title(text):
    """Set the terminal/tab title via OSC, mirroring .zshrc's _term_title. No-op when
    stdout is not a tty. Used before an execvp into ssh so the title reads `host: cmd`
    instead of the leaked ssh argv. We cannot clear it afterward (execvp replaces this
    process), but the shell's precmd refreshes the title on return."""
    if sys.stdout.isatty():
        sys.stdout.write(f"\033]0;{text}\007")
        sys.stdout.flush()


def cmd_on(cfg, args):
    if not args.rest:
        # interactive login shell on the host
        target = cfg.hosts.get(args.host, args.host)
        _set_term_title(args.host)
        os.execvp("ssh", ["ssh", "-t", target])
    host = args.host
    target = cfg.hosts.get(host, host)
    inner = " ".join(shlex.quote(a) for a in args.rest)
    _set_term_title(f"{host}: {' '.join(args.rest)}")
    os.execvp("ssh", ["ssh", "-t", target, f"zsh -lic {shlex.quote(inner)}"])


# Escape-stripping for a tmux capture-pane log of a TUI (Claude Code). The naive
# "delete \r, strip a hand-picked set of CSI letters" stripper (the old _PERL_STRIP)
# was garbage on real logs two ways: (1) deleting \r collapsed every screen REPAINT
# into one giant jammed line, and (2) its letter allowlist missed the private-mode
# CSI sequences a modern TUI emits — \x1b[>4;2m / \x1b[>1u / \x1b[<u (keyboard
# protocol) and \x1b[?25h/l (cursor show/hide) — whose `>`/`<`/`?` parameter marker
# defeated the [\d;]* match, so they leaked into less as `^Qu1u4;2m`-style junk.
# _clean_capture handles the FULL CSI grammar instead: ESC [ <params 0x30-0x3F>
# <intermediates 0x20-0x2F> <final 0x40-0x7E>. It drops every CSI EXCEPT plain SGR
# colour (final `m`, digit/semicolon params only) so `less -R` still renders colour,
# strips OSC title sets / charset selects / lone control chars, and splits on BOTH
# \r and \n so each repaint row becomes one display line. Shared by the less and the
# --dump paths so they render identically. (Residual word-jamming — "monthpriceforecast"
# — is the TUI positioning words with cursor moves we strip; reconstructing that needs a
# terminal emulator and is out of scope.)
# All stripping runs on raw BYTES, before the utf-8 decode. A tmux capture interleaves
# SO/SI charset-shift bytes (\x0e/\x0f) and escapes *inside* multibyte UTF-8 chars
# (⏵, ─, ←), so decoding first and stripping after leaves the char already mangled into
# �; stripping the control/escape bytes first makes each char's bytes contiguous so
# it decodes cleanly.
_OSC = re.compile(rb"\x1b\][^\x07\x1b]*(?:\x07|\x1b\\)")
_CSI = re.compile(rb"\x1b\[[0-?]*[ -/]*[@-~]")
_CHARSET = re.compile(rb"\x1b[()][0-9AB]")
_ESC2 = re.compile(rb"\x1b[=>Mc78]")
_CTRL = re.compile(rb"[\x00-\x08\x0b\x0c\x0e-\x1a\x1c-\x1f\x7f]")


def _keep_sgr(m):
    """CSI replacement: keep plain SGR colour (\\x1b[…m, digit/semicolon params), drop
    everything else (cursor moves, clears, private-mode toggles)."""
    s = m.group(0)
    if s[-1:] == b"m" and all(c in b"0123456789;" for c in s[2:-1]):
        return s
    return b""


def _clean_capture(logfile):
    """Read a capture-pane log, strip non-colour escapes, return one display line per
    repaint row (split on \\r and \\n)."""
    b = open(logfile, "rb").read()
    b = _OSC.sub(b"", b)
    b = _CSI.sub(_keep_sgr, b)
    b = _CHARSET.sub(b"", b)
    b = _ESC2.sub(b"", b)
    # Drop the leftover C0 control chars (BEL, the SO/SI charset shifts \x0e/\x0f that
    # show as ^N/^O, etc.) — but keep \t, \n, \r (the split feeds on \r/\n) and \x1b
    # (the surviving SGR colour sequences start with it).
    b = _CTRL.sub(b"", b)
    return re.split(r"[\r\n]+", b.decode("utf-8", "replace"))


def _infer_repo(cfg, slot=None):
    """Repo alias implied by cwd — the bin-side twin of zsh's _t_infer_repo (t read
    is bin-native so it can't call the zsh helper). Evidence is the log files
    (t read targets logs, which outlive sessions): an existing dev-<alias>-<slot>.log
    wins, then any dev-<alias>-*.log — newest mtime first either way, so when several
    aliases key one dir (dot-* and dotfiles-* both at ~/code/dotfiles) the alias
    actually in use beats a stale one. No logs → the DEV_REPOS key for the dir
    (basename match preferred, then shortest)."""
    d = cfg.repo_dir_for_cwd(os.getcwd())
    if not d:
        return None
    aliases = [k for k, v in cfg.repos.items() if v == d]
    if not aliases:
        return None
    logdir = os.path.join(HOME, ".tmux-logs")

    def newest(patterns):
        cands = []
        for k in aliases:
            for pat in patterns(k):
                if os.path.isfile(pat):
                    cands.append((os.path.getmtime(pat), k))
        return max(cands)[1] if cands else None

    if slot:
        hit = newest(lambda k: [os.path.join(logdir, f"dev-{k}-{slot}.log")])
        if hit:
            return hit
    hit = newest(lambda k: glob.glob(os.path.join(logdir, f"dev-{k}-[0-9]*.log")))
    if hit:
        return hit
    base = os.path.basename(d)
    if base in aliases:
        return base
    return min(aliases, key=len)


def cmd_read(cfg, args):
    bare = args.repo is None and args.slot is None
    repo, slot = args.repo, args.slot
    # Repo-aware: `t read 4` ≡ slot 4 of the repo cwd is in; bare `t read` is its
    # first slot's log.
    if repo is not None and repo.isdigit() and not slot:
        repo, slot = None, repo
    # Inside a slot's worktree with no slot given → default to that worktree's slot
    # (so bare `t read` in ~/code/.worktrees/<repo>/3 reads slot 3, not slot 1).
    if not slot:
        _wa, _ws = cfg.repo_of_dir(os.getcwd())
        if _ws:
            slot = _ws
    if not repo:
        repo = _infer_repo(cfg, slot or "1")
    if not repo or repo not in cfg.repos:
        _read_usage(cfg)
        return 1
    args.repo = repo
    slot = slot or "1"
    # --tail implies --dump (a tailed pager makes no sense on mobile).
    dump = args.dump or args.tail is not None
    logfile = os.path.join(HOME, ".tmux-logs", f"dev-{args.repo}-{slot}.log")
    if not os.path.isfile(logfile):
        # Same-dir sibling aliases (mirrors _dev_kill / _t_pop): `dot` and
        # `dotfiles` both key ~/code/dotfiles, so `t read dotfiles 2` should
        # also reach `dev-dot-2.log` here before delegating to a remote host.
        # _infer_repo already does this when the repo arg is omitted; this
        # handles an explicitly-named repo too.
        d = cfg.repos.get(args.repo, "")
        if d:
            for k, v in cfg.repos.items():
                if k == args.repo or v != d:
                    continue
                sib = os.path.join(HOME, ".tmux-logs", f"dev-{k}-{slot}.log")
                if os.path.isfile(sib):
                    args.repo, logfile = k, sib
                    break
    if not os.path.isfile(logfile):
        # No log here — the slot may live on a remote host (the tmux log is host-local;
        # csync syncs transcripts, not ~/.tmux-logs). Try delegating the read to that
        # host over ssh -t, which renders the remote log in less through the ssh TTY.
        # On a fully bare `t read` (no repo, no slot), probe for ANY of the inferred
        # repo's remote slots (empty slot → _dev_remote_resolve picks / fzf-picks) so a
        # remote slot other than 1 is still found. With a repo or slot explicitly named,
        # pass the resolved slot so remote mirrors the local default of slot 1.
        # --dump/--tail forward so the mobile-friendly stdout dump renders on the host.
        # rc 0 = handled (or a no-TTY hint printed); rc 1 = live nowhere → local error.
        extra = []
        if args.tail is not None:
            extra += ["--tail", str(args.tail)]
        elif dump:
            extra.append("--dump")
        if _try_remote_delegate(args.repo, "" if bare else slot, "read", extra) == 0:
            return 0
        print(f"No log found: {logfile}")
        print(f"(start a session with 't open {args.repo} {slot}' first)")
        return 1
    lines = _clean_capture(logfile)
    if dump:
        # Print straight to stdout (no pager) so a mobile terminal's native touch-scroll
        # can scroll it — `less` repaints one viewport and needs arrow/PageUp keys that
        # are unusable on a phone. --tail N keeps only the last N lines (bare --dump
        # prints all). SGR colour stays so the dump is still readable; the rest is
        # stripped by _clean_capture.
        if args.tail is not None:
            lines = lines[-args.tail:]
        sys.stdout.write("\n".join(lines) + "\n")
        return 0
    # Feed the same cleaned, repaint-split text to less -R (colour rendered, +G = tail).
    less = subprocess.Popen(["less", "-R", "+G"], stdin=subprocess.PIPE)
    less.communicate(("\n".join(lines) + "\n").encode("utf-8", "replace"))
    return 0


def _delegate(snippet):
    """exec the existing zsh implementation (login+interactive). For subprocess-safe
    verbs whose battle-tested logic stays in zsh during the hybrid migration; these
    end in a pager / tmux send-keys / tmux kill, all child-safe. (At hard cutover the
    target functions are renamed to internal _t_* helpers and these snippets follow.)"""
    os.execvp("zsh", ["zsh", "-lic", ZSH_PRELUDE + snippet])


def _try_remote_delegate(repo, slot, verb, extra=None):
    """Run zsh `_dev_remote_delegate <repo> <slot> <verb> [extra…]` (login+interactive)
    so a slot that is live on a $REMOTE_HOSTS host is handled THERE over ssh -t — the
    same shared helper `t plan`/`t pop` use. Unlike _delegate() this does NOT exec: it
    runs as a child (inheriting the TTY so the remote pager/attach works) and RETURNS the
    rc, so a bin-native verb can fall back to its local path. `extra` forwards verb flags
    (e.g. read's --dump/--tail) to the far-side `t <verb>`. rc 0 = handled (or a no-TTY
    hint was printed); rc 1 = no remote slot. Returns 1 if zsh is unavailable."""
    toks = ["_dev_remote_delegate", shlex.quote(repo), shlex.quote(slot), shlex.quote(verb)]
    toks += [shlex.quote(a) for a in (extra or [])]
    snippet = " ".join(toks)
    try:
        return subprocess.run(["zsh", "-lic", ZSH_PRELUDE + snippet]).returncode
    except OSError:
        return 1


def cmd_plan(cfg, args):
    parts = ["_t_plan"]
    if args.all:
        parts.append("--all")
    if args.repo:
        parts.append(shlex.quote(args.repo))
    if args.slot:
        parts.append(shlex.quote(args.slot))
    _delegate(" ".join(parts))


def cmd_paste(cfg, args):
    parts = ["_t_paste"]
    if args.pick:
        parts.append("--pick")
    if args.newest:
        parts.append("--newest")
    if args.repo:
        parts.append(shlex.quote(args.repo))
    if args.slot:
        parts.append(shlex.quote(args.slot))
    _delegate(" ".join(parts))


def cmd_kill(cfg, args):
    # remote kill = `_t_dev -r kill <repo> [slot]`; local = `_t_dev kill <repo> <slot|all>`
    parts = ["_t_dev", "-r", "kill"] if args.remote else ["_t_dev", "kill"]
    if args.repo:
        parts.append(shlex.quote(args.repo))
    if args.slot:
        parts.append(shlex.quote(args.slot))
    if args.yes:
        parts.append("-y")
    _delegate(" ".join(parts))


def _read_usage(cfg):
    repos = "|".join(cfg.repos) or "repo"
    print(f"t read — open a dev slot's tmux log in less\n")
    print(f"Usage: t read [{repos}] [slot] [-d|-n N]   (no repo: the one cwd is in)")
    print(f"       -d/--dump prints to stdout for mobile touch-scroll; -n N tails N lines\n")
    print("Logs:")
    logdir = os.path.join(HOME, ".tmux-logs")
    logs = sorted(f for f in os.listdir(logdir)) if os.path.isdir(logdir) else []
    logs = [f for f in logs if f.endswith(".log")]
    if logs:
        for f in logs:
            print(f"  {f[:-4]}  {os.path.join(logdir, f)}")
    else:
        print("  (none yet — start one with 't open <repo> <slot>')")


# ─── shell-bound verbs — handled by the t() zsh shim, not the bin ──────────────
# These cd the calling shell / exec `claude -r` in the current terminal / hand off
# the tpush sentinel — a subprocess cannot. The t() function in .zshrc intercepts
# them and calls the _t_dev/_t_pop/_t_push/_t_find/_t_beam helpers. Reaching the bin
# here means it was invoked DIRECTLY (e.g. `command t open`, or a context with no
# t() function) — which cannot perform the shell action.

_SHELL_BOUND = {"open", "pop", "push", "beam", "find", "__resolve"}


def cmd_pending(cfg, args):
    print(f"t {args._verb}: this verb runs in the shell via the `t` function, not the "
          f"bin. You reached bin/t directly (e.g. `command t {args._verb}`) — run "
          f"`t {args._verb} …` in an interactive zsh instead.", file=sys.stderr)
    return 2


# ─── argument parsing (gh-style) ───────────────────────────────────────────────

def build_parser():
    p = argparse.ArgumentParser(
        prog="t", description="Claude session manager (open/list/move tmux'd Claude sessions).",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
examples:
  t open api              open/reattach the next free api slot
  t open api 3 --new      force a fresh session in api slot 3
  t open                  open/reattach in the repo cwd is in
  t paste 4               slot-only args mean the cwd repo (all verbs)
  t open ff -r --new      start a fresh session on the default remote host
  t open ff --host mini   start/attach a session on 'mini' (a specific remote host)
  t open a4aa5f6a         adopt a foreground (:fg) session here (id from t ls)
  t ls                    list this repo's live sessions
  t ls -r                 list live sessions across every machine
  t push                  send the current session to a background tmux slot
  t pop api 3             pull dev-api-3 back to this terminal
  t beam api --host mini  send a session to 'mini' and resume it there
  t find "auth refactor"  search saved sessions, then resume the pick
  t on mini ls            run a command on a remote host

Run `t <verb> -h` for a verb's own flags.""")
    sub = p.add_subparsers(dest="verb", metavar="<verb>")

    sp = sub.add_parser("open", help="open or reattach a session in a per-repo tmux slot",
        description="Open or reattach a Claude session in a per-repo tmux slot. Bare `t open` "
            "(or a lone slot like `t open 3`) targets the repo your cwd is in. A slot that is "
            "live only on another host is attached in place automatically — no flag needed. "
            "`--new` forces a fresh session, `--fg` runs inline without a tmux slot, and "
            "`-r`/`--host` open or attach on a remote host (`-r --new` starts one there).")
    sp.add_argument("repo", nargs="?", help="DEV_REPOS key, or a foreground session id/repo:id from `t ls`")
    sp.add_argument("slot", nargs="?", help="slot number, 'fg' (adopt a :fg session), or a session id")
    sp.add_argument("--new", action="store_true", help="force a fresh session")
    sp.add_argument("--fg", action="store_true", help="no tmux: foreground-resume / run inline")
    sp.add_argument("-l", "--local", "--here", dest="local", action="store_true", help="force this machine: skip the remote auto-attach probe (combine with --fg for local foreground)")
    sp.add_argument("-r", "--remote", action="store_true", help="remote: attach a live slot on any host; with --new, start one on the default host")
    sp.add_argument("--host", help="which host to open/attach on (sets the host for -r; default for --new: first $REMOTE_HOSTS)")

    sp = sub.add_parser("ls", help="list dev sessions (attached + active context)",
        description="List live Claude dev sessions: whether each is attached, and whether it "
            "has an active conversation loaded (vs. parked on the startup splash). Scoped to the "
            "repo your cwd is in by default; `-a` widens to every repo, and `-r` spans every "
            "$REMOTE_HOSTS machine in one table with a HOST column. Read-only — attach with "
            "`t open`, move with `t beam`.")
    sp.add_argument("-r", "--remote", action="store_true", help="span every $REMOTE_HOSTS host")
    sp.add_argument("-a", "--all", action="store_true", help="every repo (not just the current)")

    sp = sub.add_parser("kill", help="tear down a session",
        description="Tear down a dev session (kill its tmux slot). Names default to the cwd "
            "repo, so `t kill 3` kills this repo's slot 3 and `t kill all` kills every slot for "
            "it. A foreground / :fg row from `t ls` (a bare `claude`, or a pr-watch `pr-*` "
            "session) is killed by its shown id/label — `t kill dotfiles-pr47:fg` or `t kill "
            "<short-id>` — since it is not a dev slot. Confirms first while a Claude is live "
            "unless `-y`; `-r` kills it on its remote host instead.")
    sp.add_argument("repo", nargs="?", help="DEV_REPOS key (or a :fg id/label); defaults to the repo your cwd is in")
    sp.add_argument("slot", nargs="?", help="slot number; a lone slot implies the cwd repo")
    sp.add_argument("-y", "--yes", action="store_true", help="skip the 'Claude is live' confirm")
    sp.add_argument("-r", "--remote", action="store_true", help="kill it on its host instead")

    sp = sub.add_parser("push", help="push this session into a detached background tmux slot",
        description="Push the current Claude session into a detached background tmux slot — "
            "frees this terminal while the conversation keeps running. Inside Claude it "
            "backgrounds THIS chat (and exits it for you); from a plain shell it fzf-picks a "
            "session (scoped to the cwd repo, `-a` for every project). Bring it back with "
            "`t pop`. Inverse of `t pop`.")
    sp.add_argument("-p", "--pick", action="store_true", help="force the picker")
    sp.add_argument("-a", "--all", action="store_true", help="picker across every project")

    sp = sub.add_parser("pop", help="pull a tmux'd session back to the foreground",
        description="Pull a backgrounded (tmux'd) session back into THIS terminal and resume it "
            "in the foreground. Names default to the cwd repo, so `t pop` picks this repo's slot "
            "and `t pop api 3` pulls dev-api-3. Inverse of `t push`.")
    sp.add_argument("repo", nargs="?", help="DEV_REPOS key; defaults to the repo your cwd is in")
    sp.add_argument("slot", nargs="?", help="slot number; a lone slot implies the cwd repo")

    sp = sub.add_parser("beam", help="move a session between machines (send, or --from to receive)",
        description="Move a Claude session between machines (a cross-host push/pop). By default "
            "SENDS the resolved session to --host (default $TBEAM_HOST) and resumes it there; "
            "`--from HOST` (or `--here` to auto-detect the host) RECEIVES — pulls a session "
            "living on another host down into a local slot. It is a move, not a copy: the "
            "origin's live owner is stopped so exactly one machine owns the conversation. The "
            "repo must exist at the same path on both hosts.")
    sp.add_argument("repo", nargs="?", help="DEV_REPOS key; defaults to the repo your cwd is in")
    sp.add_argument("slot", nargs="?", help="slot number; a lone slot implies the cwd repo")
    sp.add_argument("--host", help="SEND destination machine (default: $TBEAM_HOST)")
    sp.add_argument("--from", dest="from_host", metavar="HOST", help="RECEIVE: pull <repo> [slot] from HOST to this machine")
    sp.add_argument("--here", action="store_true", help="RECEIVE (auto-host): pull it back here, auto-detecting which host it is on")
    sp.add_argument("--fg", action="store_true", help="resume in the foreground, no tmux slot")
    sp.add_argument("-d", "--detach", action="store_true", help="leave it running there; print attach hint")
    sp.add_argument("-p", "--pick", action="store_true", help="force the picker")
    sp.add_argument("-a", "--all", action="store_true", help="picker across every project")
    sp.add_argument("-s", "--session", help="target a session by id or unique prefix")

    sp = sub.add_parser("read", help="read a dev slot's scrollable tmux log",
        description="Page a dev slot's captured tmux log (its scrollback) — handy for checking "
            "on a backgrounded session without attaching. Defaults to `less`; `-d`/`--dump` "
            "prints straight to stdout and `-n N`/`--tail` keeps only the last N lines (default "
            "200, implies --dump) — both for phone terminals that can only touch-scroll native "
            "output. Slot defaults to the cwd repo; a remote slot is read on its host.")
    sp.add_argument("repo", nargs="?", help="DEV_REPOS key; defaults to the repo your cwd is in")
    sp.add_argument("slot", nargs="?", help="slot number; a lone slot implies the cwd repo")
    sp.add_argument("-d", "--dump", action="store_true",
                    help="print to stdout (no less) so a mobile terminal can touch-scroll it")
    sp.add_argument("-n", "--tail", nargs="?", const=200, type=int, metavar="N",
                    help="dump only the last N lines to stdout (default 200; implies --dump)")

    sp = sub.add_parser("plan", help="render the plan a session wrote",
        description="Render the plan a Claude session last wrote (the ExitPlanMode markdown). "
            "Resolves the session like `t pop` — `t plan api 1`, a full dev-<repo>-<slot> name, "
            "or inside Claude the current session — then displays it word-wrapped for narrow "
            "(phone) terminals. `-a` fzf-picks across every project. A remote slot renders on "
            "its host, where the plan file lives.")
    sp.add_argument("repo", nargs="?", help="DEV_REPOS key; defaults to the repo your cwd is in")
    sp.add_argument("slot", nargs="?", help="slot number; a lone slot implies the cwd repo")
    sp.add_argument("-a", "--all", action="store_true", help="fzf-pick across every project")

    sp = sub.add_parser("paste", help="paste the latest iCloud screenshot/doc path into a session",
        description="Paste the path of the latest iCloud screenshot/document into a session's "
            "input — so a screenshot taken on your phone drops straight into a desktop Claude. "
            "Takes the newest file by default; `-p` fzf-picks one, `-n` forces newest. Local-"
            "only: it reads THIS machine's iCloud, so it is not delegated to a remote slot.")
    sp.add_argument("repo", nargs="?", help="DEV_REPOS key; defaults to the repo your cwd is in")
    sp.add_argument("slot", nargs="?", help="slot number; a lone slot implies the cwd repo")
    sp.add_argument("-p", "--pick", action="store_true", help="fzf-pick the file instead of taking the newest")
    sp.add_argument("-n", "--newest", action="store_true", help="skip the picker; take the newest file by mtime")

    sp = sub.add_parser("find", help="semantic search across saved sessions, then resume",
        description="Semantic search across your saved Claude transcripts (\"which session was "
            "working on X?\"), then resume the one you pick. A keyword pass builds a candidate "
            "pool, Sonnet reranks it, and every failure path (no CLI, offline, timeout) falls "
            "back to keyword order so the picker always populates. `-k` forces the offline "
            "keyword path.")
    sp.add_argument("-k", "--keyword", action="store_true", help="offline keyword ranking (no Sonnet)")
    sp.add_argument("query", nargs="*", help="search terms (omit to browse recent sessions)")

    sp = sub.add_parser("on", help="run a command on a remote host (or open a shell)",
        description="Run a command on another machine over ssh, in a login+interactive shell so "
            "the dev tooling and Homebrew are on PATH (e.g. `t on mini t ls`). With no command, "
            "opens an interactive shell there. Hosts come from $REMOTE_HOSTS; an unknown name is "
            "used as a literal ssh target.")
    sp.add_argument("host", help="$REMOTE_HOSTS key, or a literal ssh target")
    sp.add_argument("rest", nargs=argparse.REMAINDER, help="command to run (omit for an interactive shell)")

    # machine-readable / internal (hidden-ish; still have -h)
    sub.add_parser("session-rows", help="machine-readable per-host scan (remote contract)",
        description="Internal/machine-readable: emit one tab-separated row per live dev slot on "
            "this host. Part of the cross-host remote contract `t ls -r` and `t beam` run over "
            "ssh; not meant to be called directly.")
    sub.add_parser("land", help="(internal) resume a beamed session on this host",
        description="Internal: resume a just-beamed session on this (the receiving) host, "
            "reading its parameters from TB_* env vars. Invoked over ssh by `t beam`; not for "
            "direct use.")
    sub.add_parser("kill-owner", help="(internal) stop the local owner of a session id",
        description="Internal: stop the local live owner (dev slot) of a session id, enforcing "
            "`t beam`'s one-live-owner-per-conversation invariant. Invoked over ssh; not for "
            "direct use.")
    rp = sub.add_parser("__resolve", help="(internal) resolve a shell action for the t() shim",
        description="Internal: resolve a shell action for the t() zsh shim. Not for direct use.")
    rp.add_argument("rest", nargs=argparse.REMAINDER)
    return p


IMPLEMENTED = {
    "ls": cmd_ls, "session-rows": cmd_session_rows, "on": cmd_on, "read": cmd_read,
    "plan": cmd_plan, "paste": cmd_paste, "kill": cmd_kill,
    "land": cmd_land, "kill-owner": cmd_kill_owner,
}


def main(argv):
    parser = build_parser()
    args = parser.parse_args(argv)
    if not args.verb:
        parser.print_help()
        return 0
    cfg = Config()
    handler = IMPLEMENTED.get(args.verb)
    if handler:
        return handler(cfg, args)
    args._verb = args.verb
    return cmd_pending(cfg, args)


if __name__ == "__main__":
    try:
        sys.exit(main(sys.argv[1:]))
    except KeyboardInterrupt:
        sys.exit(130)
    except BrokenPipeError:
        sys.exit(0)
