#!/usr/bin/env bash
# pii-scan — fail if any cashfwd PII denylist value appears in this repo.
#
# Reuses the cashfwd two-layer ruleset:
#   1. DENYLIST  (scrub-rules.json)        — literal, case-sensitive personal
#      identifiers (real names, emails, phones, account numbers, private hosts).
#      PRIVATE — never committed here. Local: ~/code/cashfwd-private/. CI: the
#      PII_SCRUB_RULES secret, written to a temp file by the workflow.
#   2. IGNORE    (pii-ignore-patterns.txt) — regexes for documented false-positive
#      *shapes* (npm author emails, example.com, long numeric demos). No PII; tracked.
# Plus a dotfiles-specific third layer:
#   3. ALLOWLIST (pii-allowlist.txt)       — values that are intentionally public
#      in THIS repo (your own handle/email). Tracked. Lives at the repo root.
#
# A denylist value found in a file is a violation UNLESS the matched value is
# covered by an allowlist entry on the same line, or matches an ignore regex.
#
# Usage:
#   pii-scan                # scan all tracked files (git ls-files)
#   pii-scan --staged       # scan staged content only (used by the pre-commit hook)
#   pii-scan --require-rules # error if the denylist is missing (used by CI)
#
# Env overrides: PII_RULES, PII_IGNORE, PII_ALLOW.
# Exit 0 = clean, 1 = PII found, 2 = misconfiguration.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$REPO_ROOT" ]]; then
  echo "pii-scan: not inside a git repository" >&2
  exit 2
fi

RULES="${PII_RULES:-$HOME/code/cashfwd-private/scrub-rules.json}"
IGNORE="${PII_IGNORE:-$REPO_ROOT/pii-ignore-patterns.txt}"
ALLOW="${PII_ALLOW:-$REPO_ROOT/pii-allowlist.txt}"

mode="tracked"     # tracked | staged
require_rules=0
for arg in "$@"; do
  case "$arg" in
    --staged)        mode="staged" ;;
    --require-rules) require_rules=1 ;;
    -h|--help)       sed -n '2,30p' "$0"; exit 0 ;;
    *) echo "pii-scan: unknown argument: $arg" >&2; exit 2 ;;
  esac
done

if [[ ! -f "$RULES" ]]; then
  if [[ "$require_rules" == "1" ]]; then
    echo "pii-scan: denylist not found at $RULES (set PII_RULES or PII_SCRUB_RULES secret)" >&2
    exit 2
  fi
  echo "pii-scan: denylist not found at $RULES — skipping literal scan." >&2
  echo "          (install cashfwd-private or set PII_RULES; CI still scans via the secret.)" >&2
  exit 0
fi

cd "$REPO_ROOT"

PII_MODE="$mode" PII_RULES="$RULES" PII_IGNORE="$IGNORE" PII_ALLOW="$ALLOW" \
python3 - <<'PY'
import json, os, re, subprocess, sys

mode   = os.environ["PII_MODE"]
rules  = os.environ["PII_RULES"]
ignore = os.environ["PII_IGNORE"]
allow  = os.environ["PII_ALLOW"]

SKIP_PREFIXES = (".git/",)
# These files are the ruleset machinery itself — they legitimately name the
# categories/patterns and must not flag themselves.
SKIP_FILES = {
    "pii-ignore-patterns.txt",
    "pii-allowlist.txt",
}
MAX_FILE_BYTES = 2_000_000
MAX_LINE_CHARS = 4_000

# --- Layer 1: denylist (literal, case-sensitive) ----------------------------
with open(rules, encoding="utf-8") as fh:
    data = json.load(fh)
# Every list-valued, non-metadata key is a category of literal needles.
needles = []  # (value, category)
for key, val in data.items():
    if key.startswith("_") or not isinstance(val, list):
        continue
    for v in val:
        if isinstance(v, str) and v:
            needles.append((v, key))
# Longest first so the most specific value is reported when several overlap.
needles.sort(key=lambda nc: len(nc[0]), reverse=True)

# --- Layer 2: ignore patterns (regex, suppress FP shapes) -------------------
ignore_res = []
if os.path.isfile(ignore):
    with open(ignore, encoding="utf-8") as fh:
        for line in fh:
            line = line.strip()
            if line and not line.startswith("#"):
                try:
                    ignore_res.append(re.compile(line))
                except re.error:
                    pass

# --- Layer 3: allowlist (literal, intentionally-public values) --------------
allow_entries = []
if os.path.isfile(allow):
    with open(allow, encoding="utf-8") as fh:
        for line in fh:
            line = line.strip()
            if line and not line.startswith("#"):
                allow_entries.append(line)


def is_violation(value, line):
    """Decide whether `value` (a denylist hit on `line`) is a real leak.

    Returns True only if it survives both suppression layers:
      - ignore patterns: skip if `value` matches a documented false-positive shape
      - allowlist: skip if `value` is part of an intentionally-public entry that
        actually appears on this line (so whitelisting a full public email also
        clears its bare-domain substring, but only on lines that genuinely
        contain the full email).
    """
    for rx in ignore_res:
        if rx.search(value):
            return False
    for entry in allow_entries:
        if value in entry and entry in line:
            return False
    return True


# --- File list + content source ---------------------------------------------
def staged_files():
    out = subprocess.run(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=AMRC", "-z"],
        capture_output=True, text=True, check=True,
    ).stdout
    return [p for p in out.split("\0") if p]


def tracked_files():
    out = subprocess.run(["git", "ls-files", "-z"], capture_output=True, text=True, check=True).stdout
    return [p for p in out.split("\0") if p]


def read_staged(path):
    r = subprocess.run(["git", "show", f":{path}"], capture_output=True)
    return None if r.returncode != 0 else r.stdout.decode("utf-8", "ignore")


def read_tracked(path):
    try:
        if os.path.getsize(path) > MAX_FILE_BYTES:
            return None
        with open(path, encoding="utf-8", errors="ignore") as fh:
            return fh.read()
    except OSError:
        return None


files  = staged_files() if mode == "staged" else tracked_files()
reader = read_staged if mode == "staged" else read_tracked

hits = []
for path in files:
    if path in SKIP_FILES or any(path.startswith(p) for p in SKIP_PREFIXES):
        continue
    content = reader(path)
    if content is None or "\0" in content[:8000]:  # skip binaries
        continue
    for lineno, line in enumerate(content.splitlines(), 1):
        if len(line) > MAX_LINE_CHARS:
            continue
        for value, category in needles:
            if value in line and is_violation(value, line):
                hits.append((path, lineno, category, value, line.strip()))
                break  # one report per line is enough

if hits:
    print(f"\n✗ pii-scan: found {len(hits)} PII match(es) ({mode}):\n", file=sys.stderr)
    for path, lineno, category, value, line in hits:
        snippet = (line[:100] + "…") if len(line) > 100 else line
        print(f"  {path}:{lineno}  [{category}] {value!r}", file=sys.stderr)
        print(f"      {snippet}", file=sys.stderr)
    print("\nRemove the value, or — if it is intentionally public — add it to", file=sys.stderr)
    print("pii-allowlist.txt (then re-run). Bypass once with: git commit --no-verify", file=sys.stderr)
    sys.exit(1)

print(f"✓ pii-scan: no PII found ({mode}, {len(files)} files, {len(needles)} denylist values)")
PY
