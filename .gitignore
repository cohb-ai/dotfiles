.DS_Store
*.swp
.zsh_history
.zcompdump*

# Python build artifacts from bin/t (py_compile / import)
__pycache__/
*.pyc

# Per-machine/private shell config (real repo paths, hosts) — never committed.
# It lives in $HOME, not the repo, but ignore it as defense-in-depth.
.zshrc.local

# The PII denylist is private (real names/accounts/secrets) — never commit it
# here. pii-scan reads it from ~/.config/pii-scan/ locally and from the
# PII_SCRUB_RULES secret in CI.
scrub-rules.json

# Claude Code settings are per-machine: Claude writes to the live file at runtime
# (/model saves, "always allow" permission rules, plugin toggles), so only
# settings.json.example is tracked. Ignore a stray real copy as defense-in-depth.
claude/settings.json
